# ============================================================
# Copy this file to .env and fill in your values
# For Render deployment, set these in the Render dashboard
# ============================================================

# PostgreSQL Database (Render provides this automatically)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# Redis (Render provides this automatically as REDIS_URL)
REDIS_URL=redis://USER:PASSWORD@HOST:PORT

# For local development only (not needed if REDIS_URL is set)
REDIS_HOST=localhost
REDIS_PORT=6379

# AI growth assistant
# Add the real key only in .env, never commit it.
AI_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4.1-mini
AI_RECOMMENDATION_SERVICE_URL=http://localhost:3009

# Server
PORT=6789
NODE_ENV=production

# JWT Secret (use a long random string in production)
JWT_SECRET=your-super-secret-jwt-key-change-this

# Frontend URL (your Render app URL, e.g. https://ordermitra.onrender.com)
FRONTEND_URL=https://your-app-name.onrender.com

# Email (for password reset via Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
